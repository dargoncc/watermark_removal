{
  "name": "watermark-removal",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20.19.0 <23.0.0"
  },
  "scripts": {
    "dev:desktop": "pnpm --dir apps/desktop exec tauri dev",
    "dev:api": "uv run --directory services/inpaint-api uvicorn app.main:app --reload",
    "test:desktop": "pnpm --filter @watermark-removal/desktop test",
    "test:api": "uv run --directory services/inpaint-api pytest",
    "build:desktop": "pnpm --dir apps/desktop exec tauri build"
  }
}
